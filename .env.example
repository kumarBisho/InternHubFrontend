# Frontend API Configuration

# API Base URL for data requests
VITE_API_BASE_URL=http://localhost:5248/api

# API URL for other requests
VITE_API_URL=http://localhost:5248

# SignalR Hub URL for real-time features
VITE_SIGNALR_URL=http://localhost:5248/hubs

# Optional: Analytics/Monitoring
VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Optional: Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DARK_MODE=true
